JWT_SECRET=supersecretkey123
DATABASE_URL=postgresql://postgres:aminsaidane2020@db.ddvdrtsfwachlxdhuasf.supabase.co:5432/postgres
OPENAI_API_KEY=your_openai_api_key
OPENAI_TRANSCRIPTION_MODEL=whisper-1
# Optional: override python executable path if python3 is not on PATH
PYTHON_EXECUTABLE=python3

# Speech-to-text provider: local (no API key) or openai
STT_PROVIDER=local

# Local Whisper runtime settings (used when STT_PROVIDER=local)
WHISPER_MODEL_SIZE=base
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu

# Disease detection provider:
# - groq: multimodal (image + farmer title/context) via Groq vision model
# - plantid: hosted production path (recommended now)
# - hybrid: custom model first, then Plant.id if custom confidence is low
# - custom: custom model only
# - stub: local mock output
DISEASE_PROVIDER=groq

# Groq multimodal disease detection
GROQ_API_KEY=your_groq_api_key
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_API_URL=https://api.groq.com/openai/v1/chat/completions

# Plant.id hosted disease detection
PLANT_ID_API_KEY=your_plant_id_api_key
PLANT_ID_API_URL=https://api.plant.id/v2/health_assessment
PLANT_ID_IDENTIFY_URL=https://api.plant.id/v2/identify

# Override user-entered plant title only when AI plant confidence >= threshold.
# Range: 0.0 to 1.0
PLANT_NAME_OVERRIDE_THRESHOLD=0.60

# Hybrid fallback threshold (used only when DISEASE_PROVIDER=hybrid)
CUSTOM_FALLBACK_THRESHOLD=0.75